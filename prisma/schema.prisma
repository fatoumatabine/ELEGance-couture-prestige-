model Admin {
  id        Int    @id @default(autoincrement())
  username  String @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  price       Int     // Price in cents (25000 = €250)
  category    String  // robes, boubous, complets, accessoires
  gender      String? // femme, homme, enfant, accessoire
  collection  String? // grand-boubou, super-100, etc.
  subcategory String?
  featured    Boolean @default(false)
  bestSeller  Boolean @default(false)
  onSale      Boolean @default(false)
  discount    Int?
  sortOrder   Int     @default(0)
  images      String[] // Cloudinary URLs
  sizes       String[] // S, M, L, XL, etc
  colors      String[] // Noir, Rose, Blanc, etc
  inStock     Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([gender])
  @@index([collection])
  @@index([featured])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  type        String   @default("product") // product, accessory, page
  parentSlug  String?
  description String?
  image       String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([parentSlug])
  @@index([active])
}

model Collection {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  gender      String   // femme, homme, enfant
  description String?
  image       String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gender])
  @@index([active])
}

model SiteImage {
  id          Int      @id @default(autoincrement())
  title       String
  key         String   @unique // hero, home-featured, category-femme, etc.
  url         String
  alt         String?
  section     String   @default("general")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section])
  @@index([active])
}

model HomeSection {
  id          Int      @id @default(autoincrement())
  title       String
  key         String   @unique
  subtitle    String?
  ctaLabel    String?
  ctaHref     String?
  image       String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model CartItem {
  id        Int     @id @default(autoincrement())
  sessionId String
  productId Int
  quantity  Int
  size      String?
  color     String?
  createdAt DateTime @default(now())

  @@unique([sessionId, productId, size, color])
}

model Order {
  id              Int      @id @default(autoincrement())
  customerNom     String
  customerPrenom String
  customerEmail   String
  customerTelephone String
  customerAdresse String
  customerVille   String
  customerQuartier String
  customerInstructions String?
  items           Json     // [{productId, name, price, quantity, size, color, image}]
  total           Int
  fraisLivraison Int
  totalFinal      Int
  paiement        String   // cash, virement
  status          String   @default("pending") // pending, confirmed, shipped, delivered, cancelled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customerEmail])
  @@index([status])
}

model Contact {
  id          Int      @id @default(autoincrement())
  nom         String
  email       String
  telephone   String
  sujet       String
  message     String
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model Reclamation {
  id          Int      @id @default(autoincrement())
  nom         String
  email       String
  telephone   String
  commandeId  Int?
  sujet       String
  message     String
  statut      String   @default("en_attente") // en_attente, en_cours, traitee, resolue
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([commandeId])
}

model Visitor {
  id         Int      @id @default(autoincrement())
  visitorId  String   @unique
  ipHash     String?
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  visits     Int      @default(1)
  lastPath   String
  lastTitle  String?
  referrer   String?
  userAgent  String?
  deviceType String?
  browser    String?
  os         String?
  language   String?
  country    String?
  city       String?
  screen     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pageViews VisitorPageView[]

  @@index([lastSeen])
  @@index([country])
  @@index([deviceType])
}

model VisitorPageView {
  id        Int      @id @default(autoincrement())
  visitorId String
  path      String
  title     String?
  referrer  String?
  createdAt DateTime @default(now())

  visitor Visitor @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)

  @@index([visitorId])
  @@index([path])
  @@index([createdAt])
}
