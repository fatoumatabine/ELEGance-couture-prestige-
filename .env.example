# PostgreSQL - Neon (Remplacer par vos informations)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Cloudinary (Remplacer par vos informations)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Admin Authentication (Changer en production!)
ADMIN_PASSWORD="change_this_password"

# JWT Secret (Générer une clé sécurisée!)
JWT_SECRET="generate_a_secure_random_secret"

# Resend API Key (Créer sur resend.com)
RESEND_API_KEY="re_your_api_key"
